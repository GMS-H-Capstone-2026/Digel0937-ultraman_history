[
    {
        "name": "우주인 발탄성인",
        "type": "우주닌자 (Alien Baltan)",
        "origin": "발탄 행성 (행성 파괴로 우주 방랑)",
        "height": "50m",
        "weight": "15,000t",
        "desc": "초대 울트라맨의 대표적인 숙적이자 가장 인지도가 높은 외계인입니다. 가위 모양의 크고 튼튼한 양손에서 백열 광선을 발사하고, 기괴하게 분신하여 움직이는 닌자술로 울트라맨을 교란합니다. '포포포포포'하는 상징적인 웃음소리가 매우 유명합니다.",
        "image": "monster/Alien Baltan.webp"
    },
    {
        "name": "환각우주인 메트론성인",
        "type": "환각우주인 (Alien Metron)",
        "origin": "메트론 행성",
        "height": "2m ~ 50m",
        "weight": "120kg ~ 18,000t",
        "desc": "인류의 신뢰 관계를 파괴하고자 붉은 담배에 환각제를 주입해 서로 의심하게 만든 지능형 외계인입니다. 울트라세븐과 노을빛 아래 나눈 격돌과 유명한 다다미방 대화 씬이 세계적인 팬덤을 가지고 있습니다.",
        "image": "monster/Alien Metron.webp"
    },
    {
        "name": "고대괴수 고모라",
        "type": "고대괴수 (Ancient Monster)",
        "origin": "조슨 아일랜드 (고대 생존)",
        "height": "40m",
        "weight": "20,000t",
        "desc": "강력한 허리 힘에서 나오는 돌진 공격과 무자비한 메가 꼬리치기 공격으로 초대 울트라맨을 쓰러뜨렸던 정통형 고대 공룡 괴수입니다. 이후 정의로운 아군 괴수로 소환되어 큰 인기를 누렸습니다.",
        "image": "monster/Ancient Monster Gomora.webp"
    },
    {
        "name": "사신 가타노조아",
        "type": "초고대 사신 (Evil God Gatanothor)",
        "origin": "태고의 유적 루루이에",
        "height": "130m",
        "weight": "200,000t",
        "desc": "울트라맨 티가의 최종 숙적으로, 전 인류를 암흑의 절망으로 삼켜버렸던 태고의 지배자 사신입니다. 티가를 돌 석상으로 돌려놓았으나 전 세계 어린이들의 희망이 모여 부활한 글리터 티가에게 격파당했습니다.",
        "image": "monster/Evil God Gatanothor.webp"
    },
    {
        "name": "저글러스 저글러",
        "type": "환영마인 (Illusion Demon Juggler)",
        "origin": "O-50 행성 전사의 봉우리",
        "height": "1.95m ~ 50m",
        "weight": "120kg ~ 47,000t",
        "desc": "울트라맨 오브의 라이벌이자 뱀심류 발도용 칼날을 소환하는 미스터리 마인입니다. 빛에 선택받지 못한 슬픔으로 잠시 삐뚤어져 어둠의 힘을 지배하려 했으나 결국 가이와 조율하며 전장을 헤쳐 나갑니다.",
        "image": "monster/Illusion Demon Jugglus Juggler.webp"
    },
    {
        "name": "우주괴수 자밀라",
        "type": "우주괴수 (Jamila)",
        "origin": "지구 (우주 개발 도중 낙오된 비행사)",
        "height": "50m",
        "weight": "10,000t",
        "desc": "원래는 지구의 인간 우주비행사였으나 사고로 미지의 행성에 조난당하여 열악한 환경 속에서 신체가 메마른 진흙 상태 괴수로 돌변했습니다. 자신을 구조하러 오지 않고 은폐했던 지구 각국 정부에 복수하고자 침입한 비극의 괴수입니다.",
        "image": "monster/Jamila.webp"
    },
    {
        "name": "우주공룡 젯톤",
        "type": "우주공룡 (Space Dinosaur)",
        "origin": "우주 (젯톤 성인의 무장)",
        "height": "60m",
        "weight": "30,000t",
        "desc": "울트라 시리즈 최초로 **초대 울트라맨의 스페시움 광선을 전면 차단, 흡수 및 반사시켜 승리한 최강의 공룡 괴수**입니다. 단단한 껍질과 가슴의 빛나는 발광판에서 나오는 1조 도의 화염구 포격을 다룹니다.",
        "image": "monster/Space Dinosaur Zetton.webp"
    },
    {
        "name": "우주괴수 에레킹",
        "type": "우주전기괴수 (Space Monster Eleking)",
        "origin": "피트성인의 침략 병기",
        "height": "53m",
        "weight": "25,000t",
        "desc": "울트라세븐에 등장하는 호수의 수중 전기 충격 괴수입니다. 노란색 바탕에 기하학적인 까만 줄무늬와 안테나처럼 회전하는 뿔이 마스코트입니다. 상대의 몸을 꼬리로 감아 감전 스매시를 먹이는 기법이 특기입니다.",
        "image": "monster/Space Monster Eleking.webp"
    },
    {
        "name": "우주로봇 킹죠",
        "type": "4단 합체 로봇 (Space Robot King Joe)",
        "origin": "페단성인의 침략 로봇",
        "height": "55m",
        "weight": "48,000t",
        "desc": "울트라세븐에 등장한 우주 철강 특수 로봇입니다. 비행 전투정 4대로 나뉘어 날아가다 수중이나 대기에서 신속하게 결합합니다. 세븐의 모든 타격을 여유롭게 흘려내며 위용을 과시했습니다.",
        "image": "monster/Space Robot King Joe.webp"
    },
    {
        "name": "울트라맨 베리알",
        "type": "타락한 악의 군주 (Dark Ultraman)",
        "origin": "M78 성운 빛의 나라 (추방 후 레이블러드 기생)",
        "height": "55m",
        "weight": "60,000t",
        "desc": "빛의 나라를 배신하고 최악의 암흑을 거느리게 된 최초의 반역자입니다. 기가 배틀라이저를 손에 쥐고 우주 전역의 백만 대군 괴수 세력을 지휘해 빛의 나라인 M78 은하를 궤멸의 공포로 물들였습니다.",
        "image": "fake & dark ultraman list/Ultraman Belial.webp"
    },
    {
        "name": "허공괴수 그리자",
        "type": "우주의 공허 (Void Monster Greeza)",
        "origin": "존재하지 않는 차원의 틈새",
        "height": "미확정",
        "weight": "미확정",
        "desc": "울트라맨 X의 최종 보스로, 질량이나 형체, 에너지가 전혀 없는 우주의 '무(無)' 그 자체입니다. 타격 지점이 부재해 어떠한 공격도 홀로그램처럼 관통하며, 우주 생태계의 모든 생명 동력을 흡수 소멸시킵니다.",
        "image": "monster/Void Monster Greeza.webp"
    },
